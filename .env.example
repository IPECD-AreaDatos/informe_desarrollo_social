NEXT_PUBLIC_BASE_PATH=/desarrollo-social

# Docker / local (conexión directa; no usar túnel SSH)
USE_SSH_TUNNEL=false
DB_HOST=db
DB_PORT=3306
DB_USER=app
DB_PASSWORD=app
DB_NAME=informe

# PostgreSQL (login y logs de usuario)
PG_HOST=postgres
PG_PORT=5432
PG_USER=app
PG_PASSWORD=app
PG_DATABASE=informe_auth
SESSION_SECRET=cambiar-por-un-secreto-largo-en-produccion

# Opcional: prefijo o URL del API de este mismo front. Si no se define, se usa el mismo basePath que next.config (`/desarrollo-social`).
NEXT_PUBLIC_API_URL=/desarrollo-social

# Producción con túnel SSH
# USE_SSH_TUNNEL=true
# SSH_HOST=ip-o-hostname
# SSH_PORT=22
# SSH_USER=ubuntu
# SSH_PRIVATE_KEY="una sola línea con \\n entre líneas del key, ej: -----BEGIN...\\nMIIE...\\n-----END..."
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=
# DB_PASSWORD=
# DB_NAME=expediente
