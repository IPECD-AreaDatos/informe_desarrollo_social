# Docker / local (conexión directa; no usar túnel SSH)
USE_SSH_TUNNEL=false
DB_HOST=db
DB_PORT=3306
DB_USER=app
DB_PASSWORD=app
DB_NAME=informe

# URL base para la API del Frontend (útil cuando corre detrás de un reverse proxy con subrutas)
NEXT_PUBLIC_API_URL=/desarrollo-social

